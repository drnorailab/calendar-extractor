<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Card Catalog — Text to Calendar</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Source+Serif+4:wght@400;600;700&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap');

  :root{
    --ink:#1F2A24;
    --paper:#F7F3EA;
    --paper-alt:#EFE8D8;
    --accent:#2F6F5E;
    --accent-dark:#204A3F;
    --amber:#C97C3D;
    --danger:#B5493A;
    --line:#D8CFB8;
    --muted:#7A7566;
  }
  *{box-sizing:border-box;}
  body{
    margin:0;
    background:var(--paper);
    color:var(--ink);
    font-family:'Inter',sans-serif;
    background-image:
      radial-gradient(circle at 1px 1px, rgba(31,42,36,0.04) 1px, transparent 0);
    background-size:22px 22px;
  }
  .wrap{max-width:1100px;margin:0 auto;padding:36px 24px 80px;}

  header{margin-bottom:28px;}
  .eyebrow{
    font-family:'JetBrains Mono',monospace;
    font-size:11px;
    letter-spacing:0.14em;
    text-transform:uppercase;
    color:var(--accent-dark);
    display:flex;
    align-items:center;
    gap:8px;
  }
  .eyebrow::before{
    content:"";
    width:8px;height:8px;border-radius:50%;
    background:var(--amber);
    display:inline-block;
  }
  h1{
    font-family:'Source Serif 4',serif;
    font-weight:700;
    font-size:34px;
    margin:8px 0 6px;
    letter-spacing:-0.01em;
  }
  .sub{
    color:var(--muted);
    font-size:15px;
    max-width:560px;
    line-height:1.5;
  }

  .grid{
    display:grid;
    grid-template-columns:1fr 1fr;
    gap:28px;
    align-items:start;
    margin-top:28px;
  }
  @media (max-width:860px){ .grid{grid-template-columns:1fr;} }

  .panel{
    background:var(--paper-alt);
    border:1px solid var(--line);
    border-radius:2px;
    padding:20px;
    position:relative;
  }
  .panel-label{
    font-family:'JetBrains Mono',monospace;
    font-size:11px;
    letter-spacing:0.08em;
    text-transform:uppercase;
    color:var(--muted);
    margin-bottom:12px;
    display:flex;
    justify-content:space-between;
  }

  textarea{
    width:100%;
    min-height:280px;
    resize:vertical;
    background:var(--paper);
    border:1px solid var(--line);
    border-radius:1px;
    padding:14px;
    font-family:'Inter',sans-serif;
    font-size:14.5px;
    line-height:1.55;
    color:var(--ink);
  }
  textarea:focus{outline:2px solid var(--accent);outline-offset:1px;}

  .actions{margin-top:14px;display:flex;gap:10px;align-items:center;flex-wrap:wrap;}

  button{
    font-family:'Inter',sans-serif;
    font-weight:600;
    font-size:13.5px;
    border:none;
    border-radius:2px;
    padding:11px 18px;
    cursor:pointer;
    transition:transform .08s ease, background .15s ease;
  }
  button:active{transform:translateY(1px);}
  .btn-primary{background:var(--accent);color:#fff;}
  .btn-primary:hover{background:var(--accent-dark);}
  .btn-primary:disabled{background:#B9C4BE;cursor:not-allowed;}
  .btn-ghost{background:transparent;color:var(--accent-dark);border:1px solid var(--line);}
  .btn-ghost:hover{border-color:var(--accent);}

  .status{font-family:'JetBrains Mono',monospace;font-size:12px;color:var(--muted);}
  .status.err{color:var(--danger);}

  .cards{
    display:flex;
    flex-direction:column;
    gap:12px;
    min-height:280px;
  }
  .empty-state{
    border:1px dashed var(--line);
    border-radius:2px;
    padding:34px 18px;
    text-align:center;
    color:var(--muted);
    font-size:13.5px;
    line-height:1.6;
  }

  .card{
    background:var(--paper);
    border:1px solid var(--line);
    border-left:4px solid var(--amber);
    border-radius:1px;
    padding:14px 16px 14px 18px;
    position:relative;
    animation:pull .28s ease both;
  }
  .card::before{
    content:"";
    position:absolute;
    left:-4px; top:14px;
    width:10px;height:10px;
    border-radius:50%;
    background:var(--paper-alt);
    border:1px solid var(--line);
  }
  @keyframes pull{
    from{opacity:0; transform:translateX(-6px);}
    to{opacity:1; transform:translateX(0);}
  }

  .card-top{display:flex; justify-content:space-between; gap:10px; margin-bottom:8px;}
  .card-title{
    font-family:'Source Serif 4',serif;
    font-weight:600;
    font-size:16.5px;
    border:none;
    background:transparent;
    width:100%;
    color:var(--ink);
    padding:2px 0;
  }
  .card-title:focus{outline:none; border-bottom:1px solid var(--accent);}

  .remove-btn{
    background:transparent;
    border:none;
    color:var(--muted);
    font-size:16px;
    line-height:1;
    padding:2px 6px;
    cursor:pointer;
    flex-shrink:0;
  }
  .remove-btn:hover{color:var(--danger);}

  .chip-row{display:flex; flex-wrap:wrap; gap:8px; margin-bottom:8px;}
  .chip{
    font-family:'JetBrains Mono',monospace;
    font-size:12px;
    background:var(--paper-alt);
    border:1px solid var(--line);
    border-radius:20px;
    padding:5px 10px;
    display:flex;
    align-items:center;
    gap:6px;
  }
  .chip input{
    font-family:'JetBrains Mono',monospace;
    font-size:12px;
    border:none;
    background:transparent;
    color:var(--ink);
    width:auto;
  }
  .chip input[type=date]{width:118px;}
  .chip input[type=time]{width:78px;}
  .chip input:focus{outline:none;}
  .chip-label{color:var(--muted); font-size:10px; text-transform:uppercase; letter-spacing:0.05em;}

  .field-row{display:flex; gap:8px; margin-top:4px;}
  .field{flex:1;}
  .field label{
    display:block;
    font-family:'JetBrains Mono',monospace;
    font-size:10px;
    text-transform:uppercase;
    letter-spacing:0.05em;
    color:var(--muted);
    margin-bottom:3px;
  }
  .field input, .field textarea.notes{
    width:100%;
    font-family:'Inter',sans-serif;
    font-size:13px;
    border:1px solid var(--line);
    border-radius:1px;
    padding:6px 8px;
    background:var(--paper);
    color:var(--ink);
  }
  textarea.notes{resize:vertical; min-height:36px;}

  .all-day-toggle{
    font-family:'JetBrains Mono',monospace;
    font-size:11px;
    display:flex;
    align-items:center;
    gap:5px;
    color:var(--muted);
    cursor:pointer;
    user-select:none;
  }

  footer.export{
    margin-top:18px;
    padding-top:16px;
    border-top:1px solid var(--line);
    display:flex;
    justify-content:space-between;
    align-items:center;
    gap:10px;
    flex-wrap:wrap;
  }
  .count{font-family:'JetBrains Mono',monospace; font-size:12px; color:var(--muted);}
</style>
</head>
<body>
<div class="wrap">
  <header>
    <div class="eyebrow">Event extraction</div>
    <h1>Card Catalog</h1>
    <div class="sub">Paste any text that mentions dates, times, or events. Each one gets pulled out as a card you can check, edit, or remove — then export the lot as a calendar file for Outlook.</div>
  </header>

  <div class="grid">
    <div class="panel">
      <div class="panel-label"><span>Source text</span><span id="charCount">0 characters</span></div>
      <textarea id="inputText" placeholder="e.g. 'Let's meet Thursday at 3pm for the budget review, and don't forget the abstract is due July 15th. Team offsite is Aug 3-4 in Leeds.'"></textarea>
      <div class="actions">
        <button class="btn-primary" id="extractBtn">Extract events</button>
        <button class="btn-ghost" id="clearBtn">Clear</button>
        <span class="status" id="statusMsg"></span>
      </div>
    </div>

    <div class="panel">
      <div class="panel-label"><span>Detected events</span><span id="cardCount">0 found</span></div>
      <div class="cards" id="cardsContainer">
        <div class="empty-state" id="emptyState">No events yet.<br>Extracted cards will line up here for review.</div>
      </div>

      <footer class="export">
        <span class="count" id="exportCount">0 events ready</span>
        <button class="btn-primary" id="downloadBtn" disabled>Download .ics for Outlook</button>
      </footer>
    </div>
  </div>
</div>

<script>
const inputText = document.getElementById('inputText');
const charCount = document.getElementById('charCount');
const extractBtn = document.getElementById('extractBtn');
const clearBtn = document.getElementById('clearBtn');
const statusMsg = document.getElementById('statusMsg');
const cardsContainer = document.getElementById('cardsContainer');
const emptyState = document.getElementById('emptyState');
const cardCount = document.getElementById('cardCount');
const exportCount = document.getElementById('exportCount');
const downloadBtn = document.getElementById('downloadBtn');

let events = []; // {id, t, d, s, e, l, n, allDay}
let idCounter = 0;

inputText.addEventListener('input', () => {
  charCount.textContent = inputText.value.length + ' characters';
});

clearBtn.addEventListener('click', () => {
  inputText.value = '';
  charCount.textContent = '0 characters';
});

function setStatus(msg, isErr=false){
  statusMsg.textContent = msg;
  statusMsg.className = 'status' + (isErr ? ' err' : '');
}

function todayStr(){
  const d = new Date();
  return d.toISOString().slice(0,10);
}

extractBtn.addEventListener('click', async () => {
  const text = inputText.value.trim();
  if(!text){
    setStatus('Paste some text first.', true);
    return;
  }
  extractBtn.disabled = true;
  setStatus('Reading text…');

  try{
    const today = todayStr();
    const response = await fetch("https://api.anthropic.com/v1/messages", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        model: "claude-sonnet-4-6",
        max_tokens: 1000,
        system: `You are an information extraction engine. Extract every calendar-worthy event, appointment, deadline, or date/time mention from the user's text. Return ONLY valid JSON, no markdown fences, no preamble, no explanation, no trailing commentary.

Format exactly:
{"events":[{"t":"title","d":"YYYY-MM-DD","s":"HH:MM or null","e":"HH:MM or null","l":"location or null","n":"short note or null"}]}

Rules:
- Today's date is ${today}. Resolve relative dates (e.g. "next Tuesday", "tomorrow", "in two weeks") against it, and assume the nearest future occurrence when no year is given.
- If no explicit clock time is stated for an event, set "s" and "e" to null (it will be treated as an all-day event).
- If only a start time is given with no explicit end/duration, set "e" to null.
- Keep "t" under 60 characters, written as a short human title (not a quote from the text).
- "n" is optional short context, under 100 characters, or null.
- "l" is a location if one is stated, or null.
- If a date range spans multiple days (e.g. "Aug 3-4"), create one event with "d" as the start date and a note mentioning the end date.
- If you find no events at all, return {"events":[]}.
- Output nothing but the JSON object.`,
        messages: [
          { role: "user", content: text }
        ]
      })
    });

    if(!response.ok){
      throw new Error('Request failed with status ' + response.status);
    }

    const data = await response.json();
    const textBlocks = (data.content || []).filter(b => b.type === 'text').map(b => b.text).join('\n');
    let clean = textBlocks.trim().replace(/^```json/i,'').replace(/^```/,'').replace(/```$/,'').trim();

    let parsed;
    try{
      parsed = JSON.parse(clean);
    }catch(e){
      const match = clean.match(/\{[\s\S]*\}/);
      if(match){ parsed = JSON.parse(match[0]); }
      else { throw new Error('Could not parse a response'); }
    }

    const found = parsed.events || [];
    if(found.length === 0){
      setStatus('No events found in that text.');
    } else {
      setStatus(found.length + ' event' + (found.length>1?'s':'') + ' found.');
    }

    found.forEach(ev => {
      events.push({
        id: 'ev' + (idCounter++),
        t: ev.t || 'Untitled event',
        d: ev.d || today,
        s: ev.s || '',
        e: ev.e || '',
        l: ev.l || '',
        n: ev.n || '',
        allDay: !ev.s
      });
    });

    renderCards();

  }catch(err){
    console.error(err);
    setStatus('Something went wrong extracting events. Try again.', true);
  }finally{
    extractBtn.disabled = false;
  }
});

function renderCards(){
  cardsContainer.innerHTML = '';
  if(events.length === 0){
    cardsContainer.appendChild(emptyState);
    cardCount.textContent = '0 found';
    exportCount.textContent = '0 events ready';
    downloadBtn.disabled = true;
    return;
  }

  cardCount.textContent = events.length + (events.length===1?' found':' found');
  exportCount.textContent = events.length + (events.length===1?' event ready':' events ready');
  downloadBtn.disabled = false;

  events.forEach(ev => {
    const card = document.createElement('div');
    card.className = 'card';
    card.dataset.id = ev.id;

    card.innerHTML = `
      <div class="card-top">
        <input class="card-title" value="${escapeAttr(ev.t)}" data-field="t">
        <button class="remove-btn" title="Remove this event">✕</button>
      </div>
      <div class="chip-row">
        <span class="chip"><span class="chip-label">Date</span><input type="date" value="${ev.d}" data-field="d"></span>
        <span class="chip" style="${ev.allDay ? 'opacity:0.45' : ''}">
          <span class="chip-label">Start</span><input type="time" value="${ev.s || ''}" data-field="s" ${ev.allDay?'disabled':''}>
        </span>
        <span class="chip" style="${ev.allDay ? 'opacity:0.45' : ''}">
          <span class="chip-label">End</span><input type="time" value="${ev.e || ''}" data-field="e" ${ev.allDay?'disabled':''}>
        </span>
        <label class="all-day-toggle">
          <input type="checkbox" data-field="allDay" ${ev.allDay?'checked':''}> all-day
        </label>
      </div>
      <div class="field-row">
        <div class="field">
          <label>Location</label>
          <input value="${escapeAttr(ev.l)}" data-field="l" placeholder="—">
        </div>
      </div>
      <div class="field-row">
        <div class="field">
          <label>Note</label>
          <input value="${escapeAttr(ev.n)}" data-field="n" placeholder="—">
        </div>
      </div>
    `;

    card.querySelector('.remove-btn').addEventListener('click', () => {
      events = events.filter(e => e.id !== ev.id);
      renderCards();
    });

    card.querySelectorAll('[data-field]').forEach(input => {
      input.addEventListener('input', () => {
        const field = input.dataset.field;
        const target = events.find(e => e.id === ev.id);
        if(!target) return;
        if(field === 'allDay'){
          target.allDay = input.checked;
          renderCards();
          return;
        }
        target[field] = input.value;
      });
    });

    cardsContainer.appendChild(card);
  });
}

function escapeAttr(str){
  return (str || '').replace(/&/g,'&amp;').replace(/"/g,'&quot;').replace(/</g,'&lt;');
}

function escapeICS(str){
  return (str || '')
    .replace(/\\/g, '\\\\')
    .replace(/;/g, '\\;')
    .replace(/,/g, '\\,')
    .replace(/\n/g, '\\n');
}

function pad(n){ return n.toString().padStart(2,'0'); }

function icsDateStamp(){
  const d = new Date();
  return d.getUTCFullYear() + pad(d.getUTCMonth()+1) + pad(d.getUTCDate()) + 'T' +
         pad(d.getUTCHours()) + pad(d.getUTCMinutes()) + pad(d.getUTCSeconds()) + 'Z';
}

function addDays(dateStr, n){
  const d = new Date(dateStr + 'T00:00:00');
  d.setDate(d.getDate() + n);
  return d.getFullYear() + '' + pad(d.getMonth()+1) + '' + pad(d.getDate());
}

function buildICS(list){
  const lines = [
    'BEGIN:VCALENDAR',
    'VERSION:2.0',
    'PRODID:-//Card Catalog//Event Extractor//EN',
    'CALSCALE:GREGORIAN'
  ];

  list.forEach(ev => {
    const uid = ev.id + '-' + Date.now() + '@card-catalog';
    lines.push('BEGIN:VEVENT');
    lines.push('UID:' + uid);
    lines.push('DTSTAMP:' + icsDateStamp());

    const dCompact = ev.d.replace(/-/g,'');

    if(ev.allDay || !ev.s){
      lines.push('DTSTART;VALUE=DATE:' + dCompact);
      lines.push('DTEND;VALUE=DATE:' + addDays(ev.d, 1));
    } else {
      const [sh, sm] = ev.s.split(':');
      lines.push('DTSTART:' + dCompact + 'T' + pad(sh) + pad(sm) + '00');
      if(ev.e){
        const [eh, em] = ev.e.split(':');
        lines.push('DTEND:' + dCompact + 'T' + pad(eh) + pad(em) + '00');
      } else {
        const endH = (parseInt(sh) + 1) % 24;
        lines.push('DTEND:' + dCompact + 'T' + pad(endH) + pad(sm) + '00');
      }
    }

    lines.push('SUMMARY:' + escapeICS(ev.t));
    if(ev.l) lines.push('LOCATION:' + escapeICS(ev.l));
    if(ev.n) lines.push('DESCRIPTION:' + escapeICS(ev.n));
    lines.push('END:VEVENT');
  });

  lines.push('END:VCALENDAR');
  return lines.join('\r\n');
}

downloadBtn.addEventListener('click', () => {
  if(events.length === 0) return;
  const ics = buildICS(events);
  const blob = new Blob([ics], { type: 'text/calendar;charset=utf-8' });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  a.download = 'extracted-events.ics';
  document.body.appendChild(a);
  a.click();
  document.body.removeChild(a);
  URL.revokeObjectURL(url);
  setStatus('Calendar file downloaded — import it into Outlook.');
});
</script>
</body>
</html>
